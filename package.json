{
  "name": "@raunak07/pi-statusline",
  "version": "0.1.5",
  "description": "Amp-inspired status line and sticky input UI for Pi Coding Agent",
  "keywords": [
    "pi-package"
  ],
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/Raunak0713/pi-statusline.git"
  },
  "scripts": {
    "lint": "eslint .",
    "typecheck": "tsc -p tsconfig.json",
    "prepublishOnly": "npm run typecheck && npm run lint"
  },
  "files": [
    "index.ts",
    "src/",
    "themes/",
    "README.md"
  ],
  "pi": {
    "extensions": [
      "./src/index.ts"
    ],
    "themes": [
      "./themes"
    ]
  },
  "devDependencies": {
    "@earendil-works/pi-coding-agent": "0.80.10",
    "@earendil-works/pi-tui": "0.80.10",
    "@types/node": "24.13.1",
    "eslint": "^10.5.0",
    "typescript": "5.9.3",
    "typescript-eslint": "^8.62.0"
  },
  "publishConfig": {
    "access": "public"
  }
}
